# terraform.tfvars.example
# Copy to terraform.tfvars (gitignored) and fill in real values.
#
# ami_id is no longer required — resolved automatically from SSM.
# See /cloudops/dev/golden-ami/al2023-arm64/latest

region        = "us-east-1"
environment   = "dev"
project       = "cloudops"
owner         = "Rafagross"
cost_center   = "portfolio"
alert_email   = "your-email@example.com"
workload_name = "heartbeat-api"

# image_builder_logs_bucket = ""  # leave empty to reuse diagnostics bucket
